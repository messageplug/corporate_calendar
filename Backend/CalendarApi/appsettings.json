{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=calendar_db;Username=calendar_user;Password=calendar_pass"
  },
  "JwtSettings": {
    "Secret": "your-very-long-secret-key-here-at-least-32-characters",
    "Issuer": "CalendarApi",
    "Audience": "CalendarClient",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  },
  "AllowedHosts": "*"
}